<h1>Add new course</h1>

<form action='/add' method='POST'>
  <div class='input-field'>
    <input id='title' name='title' type='text' class='validate' required />
    <label for='title'>Course name</label>
    <span class='helper-text' data-error='Add name' data-success='Success'>Add course name</span>
  </div>
  <div class='input-field'>
    <input id='price' name='price' type='number' class='validate' required min='1' />
    <label for='price'>Course price</label>
    <span class='helper-text' data-error='Add price' data-success='Success'>Add course price</span>
  </div>
  <div class='input-field'>
    <input id='img' name='img' type='text' class='validate' required />
    <label for='img'>Image URL</label>
    <span class='helper-text' data-error='Add image URL' data-success='Success'>Add image URL</span>
  </div>
  <button class='waves-effect waves-light btn'>Add Course</button>
</form>