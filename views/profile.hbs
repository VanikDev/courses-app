<h1>Profile</h1>

<div class='row'>
  <div class='col s6'>
    <img
      class='avatar'
      src='https://lh3.googleusercontent.com/-3YCD3AdQrxM/AAAAAAAAAAI/AAAAAAAAAAA/ALKGfkkNWPREbkk11fqbzyRBrq6TO_07Wg/photo.jpg?sz=400'
      alt=''
    />
    <p>No avatar</p>
  </div>

  <div class='col s6'>
    <form action='/profile' method='POST'>
      <p>Your email: <strong>{{user.email}}</strong></p>
      <div class='input-field'>
        <input id='name' name='name' type='text' class='validate' value='{{user.name}}' required />
        <label for='name'>Profile name</label>
        <span class='helper-text' data-error='Name cannot be empty' data-success='Success' />
      </div>
      <form action='#'>
        <div class='file-field input-field'>
          <div class='btn'>
            <span>Avatar</span>
            <input type='file' name='avatar' />
          </div>
          <div class='file-path-wrapper'>
            <input class='file-path validate' type='text' />
          </div>
        </div>
        <input type='hidden' name='_csrf' value='{{csrf}}' />
        <button type='submit' class='btn'>Change</button>
      </form>
    </form>
  </div>
</div>